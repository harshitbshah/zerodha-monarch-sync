# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── Zerodha (kite_auth.py + sync_indian_portfolio.py) ─────────────────────────
ZERODHA_USER_ID=AB1234
ZERODHA_PASSWORD=your-zerodha-password
ZERODHA_TOTP_KEY=BASE32TOTPSECRETFROMZERODHA2FASETUP

# ── Monarch Money (sync.py + sync_us_portfolio.py) ───────────────────────────
MONARCH_TOKEN=your-monarch-api-token

# ── Google Sheets (all sync scripts) ─────────────────────────────────────────
GSHEET_SHEET_ID=your-google-sheet-id-from-url
GSHEET_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# ── PF Summary tab (sync.py) ──────────────────────────────────────────────────
GSHEET_TAB=PF Summary
GSHEET_LABEL=Indian PF
MONARCH_ACCOUNT_NAME=Zerodha
ACCOUNTS_JSON=[{"mask":"1234","sheet_category":"Bank","sheet_institution":"Chase"}]
PF_BREAKDOWN_LABEL=PF Breakdown

# ── Indian Portfolio tab (sync_indian_portfolio.py) ───────────────────────────
INDIAN_PORTFOLIO_TAB=Indian Portfolio

# ── US Portfolio tab (sync_us_portfolio.py) ───────────────────────────────────
US_PORTFOLIO_TAB=US Portfolio
